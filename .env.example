# Gmail SMTP (use an App Password, not your real password)
# Generate at: https://myaccount.google.com/apppasswords
SMTP_USER=your-email@gmail.com
SMTP_PASS='xxxx-xxxx-xxxx-xxxx'
ALERT_EMAIL_FROM=your-email@gmail.com
ALERT_EMAIL_TO=your-email@gmail.com
HEY_ADMIN_TOKEN=your-admin-token

DOG_SLUG=your-dog-slug
PUBLIC_URL="/hey-x-${DOG_SLUG}" or PUBLIC_URL=/
PRIMARY_DOMAIN=your-domain.com
TZ=Canada/Eastern
